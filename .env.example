# Copiar como .env para desarrollo local, o cargar como variables de entorno
# en Railway (Settings > Variables) para producción.

# --- Base de datos ---
# En Railway: agregar el plugin de PostgreSQL y usar la variable DATABASE_URL
# que Railway genera automáticamente (referenciar con ${{Postgres.DATABASE_URL}}).
# En local: dejar DATABASE_URL vacío y usar el desglose de abajo.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=ciemsi

# --- Autenticación ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Servidor ---
# Railway inyecta PORT automáticamente; no es necesario configurarlo ahí.
PORT=3000

# --- Email (recuperar contraseña) ---
EMAIL_USER=
EMAIL_PASS=

# --- Google OAuth / Drive (subir archivos de historial clínico) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=

# --- IA (chatbot / asistente de historia clínica) ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Firebase (notificaciones push) ---
# Local: se usa el archivo src/infrastructure/services/firebase-credentials.json (gitignored).
# Railway: no existe ese archivo en el servidor, así que se pasa el mismo JSON
# codificado en base64 en esta variable. Generar con:
#   Windows PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-credentials.json")) | Set-Clipboard
#   bash/mac/linux:       base64 -i firebase-credentials.json | tr -d '\n'
FIREBASE_CREDENTIALS_BASE64=
